# Convex deployment configuration
# Copy this file to .env.local and fill in your values

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev:your-deployment-name

# Convex cloud URL
CONVEX_URL=https://your-deployment-name.convex.cloud

# Convex site URL (for auth redirects)
CONVEX_SITE_URL=https://your-deployment-name.convex.site

# Angular environment variables (must use NG_APP_ prefix)
NG_APP_CONVEX_URL=https://your-deployment-name.convex.cloud
